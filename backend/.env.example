# ─────────────────────────────────────────────
# SolSense Backend — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# Active chain edge: solana | sui  (default: solana)
EDGE=solana

# API server port (default: 8000)
PORT=8000

# ── LLM (optional — falls back to rule-based explanations) ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com

# ── Sui Edge (only needed when EDGE=sui) ──────────────────
SUI_NETWORK=devnet
# SUI_RPC_URL=https://fullnode.devnet.sui.io:443  # override RPC
SUI_PRIVATE_KEY=                                  # bech32-encoded private key
SUISENSE_PACKAGE_ID=                              # deployed Move package ID

# Walrus (Sui edge anchoring, optional)
WALRUS_NETWORK=testnet
WALRUS_EPOCHS=1
WALRUS_DELETABLE=true

# ── Solana Edge (only needed when EDGE=solana) ────────────
SOLANA_NETWORK=mainnet-beta
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
