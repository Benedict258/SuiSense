# ─────────────────────────────────────────────
# SolSense Frontend — Environment Variables
# Copy to .env.local and fill in your values
# ─────────────────────────────────────────────

# Backend API URL (default: http://localhost:8000)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Sui package ID shown in the UI (only needed for the Sui edge)
NEXT_PUBLIC_SUISENSE_PACKAGE_ID=
